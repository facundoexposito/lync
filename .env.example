# This file is COMMITTED to git. Never put real secrets here — only placeholders.
# Copy this file to `.env.local` (gitignored) and fill real values there.

# Acuity Scheduling API (server-only — never prefix with NEXT_PUBLIC_)
ACUITY_USER_ID=
ACUITY_API_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-20
SANITY_API_TOKEN=
SANITY_REVALIDATION_SECRET=

# Airtable — quiz leads (server-only; never expose PAT to the client)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Leads

# Admin / blog publishing (server-only)
ADMIN_PASSWORD=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
